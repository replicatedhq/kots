contents:
  repositories:
    - https://apk.cve0.io
    - ./packages/
  keyring:
    - https://apk.cve0.io/key/cve0-signing.rsa.pub
    - ./melange-arm64.rsa.pub
    - ./melange-amd64.rsa.pub
  packages:
    - kurl-proxy-head  # This is expected to be built locally by `melange`.
    - bash
    - busybox
    - curl
    - git
    - securebuild-baselayout

accounts:
  groups:
    - groupname: kotsadm
      gid: 1001
  users:
    - username: kotsadm
      uid: 1001
      gid: 1001
  run-as: kotsadm

environment:
  VERSION: ${GIT_TAG}

cmd: /kurl_proxy
